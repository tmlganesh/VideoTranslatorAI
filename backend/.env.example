# No external API keys required.
# Hybrid translation routing:
# - en<->te uses mT5 checkpoint
# - all other language pairs use Marian/opus-mt with English pivot fallback

# Enable mT5 route for English<->Telugu
ENABLE_MT5_EN_TE_ROUTING=true

# Path or HF model ID for EN<->TE mT5 checkpoint
# For production, point this to your fine-tuned checkpoint directory.
MT5_EN_TE_MODEL_PATH=google/mt5-small

# Generation token limits for mT5 route
MT5_MAX_SOURCE_TOKENS=256
MT5_MAX_TARGET_TOKENS=256
